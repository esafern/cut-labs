{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://cut-labs.local/schemas/packet-telemetry-value-v2.json",
  "title": "CUT Packet Telemetry",
  "description": "Per-packet metadata extracted by the CUT relay (WIRE fields) with optional engine enrichment (COMPUTED fields). Patent ref: US 12,309,132 B1, FIG.1 elements 114 (relay) and 120 (time-series DB).",
  "type": "object",
  "required": [
    "src_ip",
    "src_port",
    "dst_ip",
    "dst_port",
    "timestamp_epoch",
    "ip_proto",
    "tcp_flags_hex",
    "seq_raw",
    "ack_raw",
    "win_value",
    "tcp_payload_len",
    "direction"
  ],
  "properties": {

    "src_ip":           { "type": "string",  "description": "WIRE. Source IP address." },
    "src_port":         { "type": "integer", "description": "WIRE. Source TCP port." },
    "dst_ip":           { "type": "string",  "description": "WIRE. Destination IP address." },
    "dst_port":         { "type": "integer", "description": "WIRE. Destination TCP port." },
    "timestamp_epoch":  { "type": "string",  "description": "WIRE. Capture timestamp, nanosecond Unix epoch." },
    "direction":        { "type": "string",  "enum": ["outbound", "inbound"], "description": "WIRE. Packet direction relative to normalized session key. outbound = src is lower endpoint, inbound = src is higher endpoint." },
    "ttl":              { "type": "integer", "description": "WIRE. IP Time to Live." },
    "ip_id":            { "type": "string",  "description": "WIRE. IP identification field." },
    "ip_len":           { "type": "integer", "description": "WIRE. Total IP datagram length." },
    "dscp":             { "type": "integer", "description": "WIRE. Differentiated Services Code Point." },
    "ecn":              { "type": "integer", "description": "WIRE. Explicit Congestion Notification." },
    "df":               { "type": "string",  "description": "WIRE. Don't Fragment flag." },
    "ip_proto":         { "type": "integer", "description": "WIRE. IP protocol number. 6=TCP, 17=UDP." },
    "tcp_flags_hex":    { "type": "string",  "description": "WIRE. Raw TCP flags byte as hex." },
    "tcp_flags_str":    { "type": "string",  "description": "WIRE. TCP flags as visual string." },
    "tcp_flags_cwr":    { "type": "string",  "description": "WIRE. Congestion Window Reduced flag." },
    "tcp_flags_ece":    { "type": "string",  "description": "WIRE. ECN-Echo flag." },
    "seq_raw":          { "type": "string",  "description": "WIRE. Absolute TCP sequence number." },
    "ack_raw":          { "type": "string",  "description": "WIRE. Absolute TCP acknowledgment number." },
    "win_value":        { "type": "integer", "description": "WIRE. Raw TCP window size before scaling." },
    "tcp_payload_len":  { "type": "integer", "description": "WIRE. TCP payload bytes." },
    "tcp_hdr_len":      { "type": "integer", "description": "WIRE. TCP header length." },
    "urgent_ptr":       { "type": "integer", "description": "WIRE. TCP urgent pointer." },
    "mss":              { "type": "integer", "description": "WIRE. Maximum Segment Size (SYN only)." },
    "wscale":           { "type": "integer", "description": "WIRE. Window scale factor (SYN only)." },
    "ts_val":           { "type": "string",  "description": "WIRE. TCP timestamp value." },
    "ts_ecr":           { "type": "string",  "description": "WIRE. TCP timestamp echo reply." },
    "tcp_options_raw":  { "type": "string",  "description": "WIRE. Raw TCP options bytes." },

    "time_delta":       { "type": "string",  "description": "COMPUTED. Optional. Inter-packet arrival time." },
    "frame_len":        { "type": "integer", "description": "COMPUTED. Optional. Total frame bytes." },
    "protocols":        { "type": "string",  "description": "COMPUTED. Optional. Protocol stack string." },
    "tcp_stream":       { "type": "integer", "description": "COMPUTED. Optional. Stream reassembly index." },
    "is_retransmit":    { "type": "string",  "description": "COMPUTED. Optional. Retransmission flag." },
    "is_zero_window":   { "type": "string",  "description": "COMPUTED. Optional. Zero window flag." },
    "initial_rtt":      { "type": "string",  "description": "COMPUTED. Optional. SYN-to-SYN-ACK delta." },
    "ack_rtt":          { "type": "string",  "description": "COMPUTED. Optional. Per-packet RTT." },
    "bytes_in_flight":  { "type": "integer", "description": "COMPUTED. Optional. Unacknowledged bytes." }
  },
  "additionalProperties": false
}
